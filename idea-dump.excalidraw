      "index": "ao",
      "roundness": null,
      "seed": 686626925,
      "version": 1108,
      "versionNonce": 217675181,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1758946834695,
      "link": null,
      "locked": false,
      "text": "- Tour view pages\n    x T0 (Home page) --> includes search bar to search up common tours, \n       tour query results, tour creation button\n    x TOA (Alternative home page) --> Copy of T0 + additional display of saved tours\n    x TOS (Home page when searching) --> shows view of home page when you're searching for queries\n    x T1 (Create a tour page) --> includes search bar, supports adding removing sites\n    x T2 (Tour overview page) --> view tour on map / remove sites, and optionally save tour for public  \n    x T3 (Tour over view page 2) --> Optionally add details to your tour / make available to public",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Tour view pages\n    x T0 (Home page) --> includes search bar to search up common tours, \n       tour query results, tour creation button\n    x TOA (Alternative home page) --> Copy of T0 + additional display of saved tours\n    x TOS (Home page when searching) --> shows view of home page when you're searching for queries\n    x T1 (Create a tour page) --> includes search bar, supports adding removing sites\n    x T2 (Tour overview page) --> view tour on map / remove sites, and optionally save tour for public  \n    x T3 (Tour over view page 2) --> Optionally add details to your tour / make available to public",
      "autoResize": true,
      "lineHeight": 1.25
    },
