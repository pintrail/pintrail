    {
      "id": "7zSYFWsaKZl86qJ0maj0U",
      "type": "text",
      "x": 286.34276328912705,
      "y": -76.90121819777735,
      "width": 813.0074462890625,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
