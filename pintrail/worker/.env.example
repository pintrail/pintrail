# Environment Variables Reference
# These are for documentation only. In production, pass environment variables
# via Docker Compose (compose.yml or compose.prod.yml).
# For local development, export these variables:
#   export DB_HOST=localhost DB_PORT=5432 DB_USER=pintrail ...
# Or use direnv with a .envrc file.

# Database (PostgreSQL) — must match portal/pt2
DB_HOST=localhost
DB_PORT=5432
DB_USER=pintrail
DB_PASSWORD=pintrail
DB_NAME=pintrail

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
IMAGE_QUEUE_NAME=artifact-image-processing

# Storage — must point to the same volume as portal
IMAGE_STORAGE_ROOT=./data/images
